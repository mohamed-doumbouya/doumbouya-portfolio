@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Contact";
}
@model MyPortfolio.Domain.Models.ViewModels.ContactViewModel

<section id="contact" class="contact section">

    <div class="container section-title" data-aos="fade-up">
        <h2>Contact</h2>
        <p>Let’s connect ! Whether for collaboration, inquiries, or new opportunities, feel free to reach out.</p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row gy-4">
            <div class="col-lg-5">

                <div class="info-wrap">
                    <div class="info-item d-flex" data-aos="fade-up" data-aos-delay="200">
                        <i class="bi bi-geo-alt flex-shrink-0"></i>
                        <div>
                            <h3>Workplace</h3>
                            <p>BPCE Tower, East Paris, France</p>
                        </div>
                    </div><!-- End Info Item -->
                    <iframe src="https://www.google.com/maps?q=Tour%20BPCE%20Paris%20Est&output=embed" frameborder="0" style="border:0; width: 100%; height: 270px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </div>

            <div class="col-lg-7">
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger">
                        <strong>Please correct the following errors:</strong>
                        <ul>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        </ul>
                    </div>
                }

                <form asp-action="Index" method="post" class="php-email-form" data-aos="fade-up" data-aos-delay="200">
                    @Html.AntiForgeryToken()

                    <div class="row gy-4">

                        <div class="col-md-6">
                            <label asp-for="SenderName" class="pb-2">Your Name</label>
                            <input asp-for="SenderName" class="form-control" />
                            <span asp-validation-for="SenderName" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="SenderEmailAdress" class="pb-2">Your Email</label>
                            <input asp-for="SenderEmailAdress" class="form-control" />
                            <span asp-validation-for="SenderEmailAdress" class="text-danger"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Subject" class="pb-2">Subject</label>
                            <input asp-for="Subject" class="form-control" />
                            <span asp-validation-for="Subject" class="text-danger"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Message" class="pb-2">Message</label>
                            <textarea asp-for="Message" class="form-control" rows="6"></textarea>
                            <span asp-validation-for="Message" class="text-danger"></span>
                        </div>

                        <div class="col-md-12 text-center">
                            <button type="submit" class="btn-submit">Send Message</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}