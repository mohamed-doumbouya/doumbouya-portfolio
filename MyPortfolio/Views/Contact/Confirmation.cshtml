@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Thank you";
}
<div class="page-title dark-background">
    <div class="container d-lg-flex justify-content-between align-items-center">
        <h1 class="mb-2 mb-lg-0">Confirmation</h1>
        <nav class="breadcrumbs">
            <ol>
                <li><a asp-controller="Contact" asp-action="Index">Contact</a></li>
                <li class="current">Email confirmation</li>
            </ol>
        </nav>
    </div>
</div><!-- End Page Title -->

<section id="service-details" class="service-details section">

    <div class="container">

        <div class="row gy-4 justify-content-center">

            <div class="col-lg-8" data-aos="fade-up" data-aos-delay="200">

                <div class="confirmation-box text-center">
                    <div class="confirmation-icon">
                        ✓
                    </div>

                    <h3>Message Sent Successfully</h3>

                    <p>
                        Thank you for reaching out. Your message has been received successfully.
                    </p>

                    <p class="confirmation-sub">
                        I will review your request and get back to you as soon as possible.
                    </p>

                    <a href="/" class="btn-return">Back to Home</a>
                </div>

            </div>

        </div>

    </div>

</section>