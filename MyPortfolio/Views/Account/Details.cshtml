@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "About";
}
@model MyPortfolio.Domain.DTO.UserDto

<!-- About Section -->
<section id="about" class="about section">

    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>About</h2>
        <p>
            Driven by a passion for technology, culture, and social impact, I’m a software engineer with a vision beyond code.
            My educational journey has been shaped by incredible opportunities, including the support of
            <a href="https://www.facebook.com/promoguinee/" target="_blank">Promo-Guinée</a>, an NGO that granted me a scholarship
            to continue my secondary education at Sainte Marie de Dixinn High School after ranking 11th in the Special Zone of Conakry
            in the BEPC exams, following my time at Collège 2 Bonfi. Thanks to Promo-Guinée’s support, I was able to pursue my academic
            ambitions, laying the foundation for my later achievements.
        </p>
        <p>
            Alongside my professional work, I actively engage in associations, explore music, and embrace the arts.
            I’m committed to leveraging my skills to create innovative tech and socio-economic projects that contribute
            to the development of <span style="color: #149ddd;">Guinea</span> and beyond. Combining technical expertise with a deep sense
            of purpose, I aim to make a meaningful impact on both the digital and real-world landscapes.
            To support their work, you can also visit
            <a href="http://www.promoguinee.org/donate.php?fbclid=IwY2xjawQYGDpleHRuA2FlbQIxMABzcnRjBmFwcF9pZBAyMjIwMzkxNzg4MjAwODkyAAEeBbcBVBHuOmCyhYlsO3UgkMvA4EOhXmtueLvwVccCQr7OeSdaESC2N7jyK9A_aem_VGoPEzDfx9miYZo5pyvmyQ" target="_blank">Promo-Guinée’s website</a>.
        </p>
    </div><!-- End Section Title -->

    <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row gy-4 justify-content-center">
            <div class="col-lg-4">
                <img src="@Url.Content("~/images/profile-img.jpeg")" class="img-fluid" alt="">
            </div>
            <div class="col-lg-8 content">
                <h2>@Model.Profession</h2>
                <p class="fst-italic py-3">
                    @Model.Summary
                </p>
                <div class="row">
                    <div class="col-lg-6">
                        <ul>
                            <li> <strong>Birthday:</strong> <span>@Model.Birthday.ToString("dd/MM/yyyy")</span></li>
@*                             <li> <strong>Website:</strong> <span>@Model.Website</span></li>
 *@                            <li> <strong>Phone:</strong> <span>@Model.Phone</span></li>
                            <li> <strong>City:</strong> <span>@string.Concat(Model.Adress?.City, ", ", Model.Adress?.Country)</span></li>
                        </ul>
                    </div>
                    <div class="col-lg-6">
                        <ul>
                            <li> <strong>Age:</strong> <span>@Model.Age</span></li>
                            <li> <strong>Degree:</strong> <span>@Model.Degree</span></li>
                            <li>
                                 <strong>Email:</strong> <span>
                                    <a href="mailto:@Model.Email">
                                        Contact me by email
                                    </a>
                                </span>
                            </li>
                            <li> <strong>Freelance:</strong> <span>@Model.Freelance</span></li>
                        </ul>
                    </div>
                </div>
                <p class="py-3">
                    By working together, you’ll benefit from a blend of technical expertise, creativity, and a strong sense of purpose. I bring a passion for continuous learning, a commitment to high-quality solutions, and a drive to make a positive impact through technology and innovation. Whether tackling complex projects or exploring new ideas, I strive to deliver results that matter, all while fostering a collaborative and dynamic environment. Let’s create something impactful together!
                </p>
            </div>
        </div>

    </div>

</section>

<!-- /About Section -->

<!-- Skills Section -->
@if (Model.Skills != null && Model.Skills.Any())
{
    <section id="skills" class="skills section light-background">

        <!-- Section Title -->
        <div class="container section-title" data-aos="fade-up">
            <h2>Skills</h2>
            <p>A blend of technical expertise and problem-solving abilities that drive my work. Here’s a breakdown of my key skills and proficiency levels</p>
        </div><!-- End Section Title -->

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="row skills-content skills-animation">

                <div class="col-lg-6">
                    @{
                        int middleIndex = (int)Math.Ceiling(Model.Skills.Count() / 2.0);
                        var firstHalf = Model.Skills.Take(middleIndex).ToList();
                        var secondHalf = Model.Skills.Skip(middleIndex).ToList();
                    }

                    @foreach (var skill in firstHalf)
                    {
                        <div class="progress">
                            <span class="skill"><span>@skill.Name</span> <i class="val">@skill.Percentage.ToString()%</i></span>
                            <div class="progress-bar-wrap">
                                <div class="progress-bar" role="progressbar" aria-valuenow=@skill.Percentage.ToString() aria-valuemin="0" aria-valuemax=@skill.Percentage.ToString()></div>
                            </div>
                        </div>

                        <!-- End Skills Item -->
                    }
                </div>

                <div class="col-lg-6">
                    @foreach (var skill in secondHalf)
                    {
                        <div class="progress">
                            <span class="skill"><span>@skill.Name</span> <i class="val">@skill.Percentage.ToString()%</i></span>
                            <div class="progress-bar-wrap">
                                <div class="progress-bar" role="progressbar" aria-valuenow=@skill.Percentage.ToString() aria-valuemin="0" aria-valuemax=@skill.Percentage.ToString()></div>
                            </div>
                        </div>

                        <!-- End Skills Item -->
                    }
                </div>

            </div>

        </div>

    </section>

    <!-- /Skills Section -->
}
