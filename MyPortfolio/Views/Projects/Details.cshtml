@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Project details";
}
@model MyPortfolio.Domain.DTO.ProjectDto

<div class="portfolio-details-page">
    <div class="page-title dark-background">
        <div class="container d-lg-flex justify-content-between align-items-center">
            <h1 class="mb-2 mb-lg-0">Project Details</h1>
            <nav class="breadcrumbs">
                <ol>
                    <li><a asp-controller="Projects" asp-action="Index">Project</a></li>
                    <li class="current">Project Details</li>
                </ol>
            </nav>
        </div>
    </div>

    <section id="portfolio-details" class="portfolio-details section">

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="container">

                <!-- ROW 1 : Image + Project Info -->
                <div class="row gy-4">

                    <div class="col-lg-8">
                        <div class="portfolio-details-slider swiper init-swiper">

                            <script type="application/json" class="swiper-config">
                                {
                                  "loop": true,
                                  "speed": 600,
                                  "autoplay": {
                                    "delay": 5000
                                  },
                                  "slidesPerView": "auto",
                                  "pagination": {
                                    "el": ".swiper-pagination",
                                    "type": "bullets",
                                    "clickable": true
                                  }
                                }
                            </script>

                            <div class="swiper-wrapper align-items-center">

                                <div class="swiper-slide">
                                    <img src="@Url.Content(Model.ImageUrl)" class="img-fluid" alt="">
                                </div>

                            </div>

                            <div class="swiper-pagination"></div>

                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="portfolio-info" data-aos="fade-up" data-aos-delay="200">
                            <h3>@Model.Title</h3>
                            <ul>
                                <li><strong>Category</strong>: @Model.Category</li>
                                <li><strong>Client</strong>: @Model.Client</li>
                                <li><strong>Project start date</strong>: @Model.StartDate</li>

                                @if (Model.EndDate.HasValue && Model.EndDate.Value != default(DateTime))
                                {
                                    <li><strong>Project end date</strong>: @Model.EndDate.Value.ToString("dd/MM/yyyy")</li>
                                }
                                else
                                {
                                    <li><strong>Project end date</strong>: In progress</li>
                                }

                                <li>
                                    <strong>Project URL</strong>:
                                    <a href="@Model.ProjectURL" target="_blank">
                                        View the project website
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>

                </div>

                <!-- ROW 2 : Summary + Description -->
                <div class="row mt-4">

                    <div class="col-lg-12">
                        <div class="portfolio-description" data-aos="fade-up" data-aos-delay="300">

                            <h2>@Model.Summary</h2>

                            <p>
                                @Model.Description
                            </p>

                        </div>
                    </div>

                </div>

            </div>

        </div>

    </section>
</div>