@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Resume";
}
@model MyPortfolio.Domain.Models.ViewModels.ResumeDetailsViewModel

<!-- Resume Section -->
<section id="resume" class="resume section">

    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>Resume</h2>
        <p>Passionate about software development, I design high-performance and secure solutions in .NET and Ruby, applying best practices (Clean Code, TDD, DDD). Curious and detail-oriented, I thrive on tackling technical challenges and optimizing systems for efficiency and reliability.</p>
        <a asp-controller="Resume" asp-action="DownloadPdf" class="download-resume-btn">
            <i class="bi bi-download"></i> Download Resume (PDF)
        </a>
    </div><!-- End Section Title -->

    <div class="container">

        <div class="row">

            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="100">
                <h3 class="resume-title">Summary</h3>

                <div class="resume-item pb-0">
                    <h4>@string.Concat(Model.UserDTO.FirstName, " ", Model.UserDTO.LastName)</h4>
                    <p><em>@Model.UserDTO.Summary</em></p>
                    <ul>
                        <li>@string.Concat(Model.UserDTO.Adress?.City, ", ", Model.UserDTO.Adress?.Country)</li>
                        <li>@Model.UserDTO.Phone</li>
                        <li>
                            <strong>Email:</strong> <span>
                                <a href="mailto:@Model.UserDTO.Email">
                                    Contact me by email
                                </a>
                            </span>
                        </li>
                    </ul>
                </div><!-- End Resume Item -->
                @if (Model.ResumeDTO != null && Model.ResumeDTO.Educations != null && Model.ResumeDTO.Educations.Any())
                {
                    <h3 class="resume-title">Education</h3>
                    @foreach (var education in Model.ResumeDTO.Educations)
                    {
                        <div class="resume-item education-item">
                            <div class="education-header">
                                @if (!string.IsNullOrEmpty(education.LogoUrl))
                                {
                                    <img src="@Url.Content(education.LogoUrl)" class="school-logo" alt="@education.Name logo" />
                                }
                                <div class="education-title">
                                    <h4>@education.Certification</h4>
                                    <h5>
                                        @education.StartDate.Year -
                                        @(education.EndDate?.Year.ToString() ?? "Present")
                                    </h5>
                                </div>
                            </div>

                            <p class="school-name">
                                <em>
                                    @education.Name, @education.City, @education.Country
                                </em>
                                @if (!string.IsNullOrEmpty(education.Website))
                                {
                                    <a href="@education.Website" target="_blank" rel="noopener noreferrer"
                                       class="school-website" title="Visit official website">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                        <span class="website-text">Official Website</span>
                                    </a>
                                }
                            </p>

                            @if (!string.IsNullOrEmpty(education.Description))
                            {
                                <p>@education.Description</p>
                            }
                        </div>
                        <!-- End Resume Item -->
                    }
                }
            </div>

            @if (Model.ResumeDTO != null && Model.ResumeDTO.Experiences != null && Model.ResumeDTO.Experiences.Any())
            {
                <div class="col-lg-6" data-aos="fade-up" data-aos-delay="200">
                    <h3 class="resume-title">Professional Experience</h3>
                    @foreach (var experience in Model.ResumeDTO.Experiences)
                    {
                        <div class="resume-item experience-item">
                            <div class="experience-header">
                                <h4>@experience.Role</h4>
                                <h5>
                                    @experience.StartDate.Year -
                                    @(experience.EndDate?.Year.ToString() ?? "Present")
                                </h5>
                            </div>

                            <p class="company-name">
                                <em>@experience.EntrepriseName, @experience.City, @experience.Country</em>
@*                                 @if (!string.IsNullOrEmpty(experience.CompanyWebsite))
                                {
                                    <a href="@experience.CompanyWebsite" target="_blank" rel="noopener noreferrer"
                                       class="company-website" title="Visit company website">
                                        <i class="bi bi-building"></i>
                                    </a>
                                } *@
                            </p>

                            @if (experience.Missions != null && experience.Missions.Any())
                            {
                                <ul>
                                    @foreach (var mission in experience.Missions)
                                    {
                                        <li>@mission.Description</li>
                                    }
                                </ul>
                            }
                        </div>
                        <!-- End Resume Item -->
                    }
                </div>
            }

        </div>

    </div>

</section>
<!-- /Resume Section -->