@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Services";
}
@model MyPortfolio.Domain.Models.ViewModels.ServiceViewModel

<section id="services" class="services section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Services</h2>
        <p>Offering tailored solutions in software development, architecture, and technical consulting. Here's how I can help bring your ideas to life.</p>
    </div>

    <div class="container">
        @if (Model.Services != null && Model.Services.Any())
        {
            <div class="row gy-4">
                @foreach (var service in Model.Services)
                {
                    <div class="col-lg-4 col-md-6 service-item d-flex" data-aos="fade-up" data-aos-delay="100">
                        <div class="icon flex-shrink-0"><i class="bi bi-briefcase"></i></div>
                        <div>
                            <h4 class="title"><a asp-controller="Services" asp-action="Details" asp-route-id="@service.Id" class="stretched-link">@service.Title</a></h4>
                            <p class="description">@service.Summary</p>
                        </div>
                    </div>
                    <!-- End Service Item -->
                }
            </div>
        }

    </div>
</section>

@if (Model.Testimonials != null && Model.Testimonials.Any())
{
    <section id="testimonials" class="testimonials section light-background">

        <!-- Section Title -->
        <div class="container section-title" data-aos="fade-up">
            <h2>Testimonials</h2>
            <p>Here's what my teammates and clients say about working with me.</p>
        </div><!-- End Section Title -->

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <div class="swiper init-swiper">
                <script type="application/json" class="swiper-config">
                    {
                      "loop": true,
                      "speed": 600,
                      "autoplay": {
                        "delay": 5000
                      },
                      "slidesPerView": "auto",
                      "pagination": {
                        "el": ".swiper-pagination",
                        "type": "bullets",
                        "clickable": true
                      },
                      "breakpoints": {
                        "320": {
                          "slidesPerView": 1,
                          "spaceBetween": 40
                        },
                        "1200": {
                          "slidesPerView": 3,
                          "spaceBetween": 1
                        }
                      }
                    }
                </script>
                <div class="swiper-wrapper">
                    @foreach (var testimonial in Model.Testimonials)
                    {
                        <div class="swiper-slide">
                            <div class="testimonial-item">
                                <p>
                                    <i class="bi bi-quote quote-icon-left"></i>
                                    <span>@testimonial.Content</span>
                                    <i class="bi bi-quote quote-icon-right"></i>
                                </p>

                                <img src="@Url.Content(testimonial.AuthorImage)" class="testimonial-img" alt="@testimonial.Author">
                                <h3>@testimonial.Author</h3>
                                <h4>@testimonial.AuthorProfession</h4>

                                @if (!string.IsNullOrEmpty(testimonial.LinkedInUrl) ||
                                                        !string.IsNullOrEmpty(testimonial.PortfolioUrl) ||
                                                        !string.IsNullOrEmpty(testimonial.GitHubUrl))
                                {
                                    <div class="testimonial-profiles">
                                        @if (!string.IsNullOrEmpty(testimonial.LinkedInUrl))
                                        {
                                            <a href="@testimonial.LinkedInUrl" target="_blank" rel="noopener noreferrer"
                                               class="profile-link linkedin" title="View on LinkedIn">
                                                <i class="bi bi-linkedin"></i>
                                            </a>
                                        }

                                        @if (!string.IsNullOrEmpty(testimonial.PortfolioUrl))
                                        {
                                            <a href="@testimonial.PortfolioUrl" target="_blank" rel="noopener noreferrer"
                                               class="profile-link portfolio" title="Visit Portfolio/Website">
                                                <i class="bi bi-briefcase"></i>
                                            </a>
                                        }

                                        @if (!string.IsNullOrEmpty(testimonial.GitHubUrl))
                                        {
                                            <a href="@testimonial.GitHubUrl" target="_blank" rel="noopener noreferrer"
                                               class="profile-link github" title="View on GitHub">
                                                <i class="bi bi-github"></i>
                                            </a>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                        <!-- End testimonial item -->
                    }
                </div>
                <div class="swiper-pagination"></div>
            </div>

        </div>

    </section>
}

<style>
    /* Testimonials Profiles Styling */
    .testimonial-profiles {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-top: 15px;
        padding-top: 10px;
        border-top: 1px solid rgba(0,0,0,0.05);
    }

    .profile-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        color: white;
        transition: all 0.3s ease;
        text-decoration: none;
        font-size: 1.1rem;
    }

        .profile-link.linkedin {
            background: #0077b5;
        }

        .profile-link.portfolio {
            background: var(--accent-color, #149ddd);
        }

        .profile-link.github {
            background: #333;
        }

        .profile-link:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .profile-link.linkedin:hover {
            background: #005e8c;
        }

        .profile-link.portfolio:hover {
            background: color-mix(in srgb, var(--accent-color, #149ddd), black 20%);
        }

        .profile-link.github:hover {
            background: #24292e;
        }

    /* Ensure testimonial images are properly sized */
    .testimonial-img {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        object-fit: cover;
        margin: 0 auto 15px;
        border: 3px solid var(--accent-color, #149ddd);
        padding: 3px;
    }

    .testimonial-item {
        text-align: center;
        padding: 30px 20px;
        background: var(--surface-color);
        border-radius: 10px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        height: 100%;
        min-height: 380px;
        display: flex;
        flex-direction: column;
    }

        .testimonial-item p {
            font-style: italic;
            margin-bottom: 20px;
            flex-grow: 1;
        }

        .testimonial-item h3 {
            font-size: 1.2rem;
            margin-bottom: 5px;
            color: var(--heading-color);
        }

        .testimonial-item h4 {
            font-size: 0.9rem;
            color: var(--default-color);
            opacity: 0.8;
            margin-bottom: 0;
        }

    .quote-icon-left, .quote-icon-right {
        color: var(--accent-color, #149ddd);
        opacity: 0.3;
    }

    .quote-icon-left {
        margin-right: 5px;
    }

    .quote-icon-right {
        margin-left: 5px;
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .testimonial-item {
            min-height: auto;
            padding: 25px 15px;
        }

        .testimonial-profiles {
            gap: 8px;
        }

        .profile-link {
            width: 32px;
            height: 32px;
            font-size: 1rem;
        }
    }
</style>