@{
    ViewData["Title"] = "Home Page";
}
@model MyPortfolio.Domain.Models.ViewModels.UserInfoViewModel

@if (Model.UserDTO != null)
{
    <!-- Hero Section -->
    <section id="hero" class="hero section dark-background">

        <img src="@Url.Content("~/images/baner.png")" alt="" data-aos="fade-in" class="">

        <div class="container" data-aos="fade-up" data-aos-delay="100">
            <h2>@string.Concat(Model.UserDTO.FirstName, " ", Model.UserDTO.LastName)</h2>
            <p>I'm <span class="typed" data-typed-items="Software Engineer, Tech Mentor, Tech Speaker, Digital Builder">Software Engineer</span><span class="typed-cursor typed-cursor--blink" aria-hidden="true"></span><span class="typed-cursor typed-cursor--blink" aria-hidden="true"></span></p>
            <p class="vision">
                Driving IT innovation in Guinea and promoting Education, Art & Culture.
            </p>
            <div class="hero-buttons">
                <a asp-controller="Resume" asp-action="Details" asp-active-by="Index" asp-active-type="action" class="btn-main">Discover My Journey</a>
                <a asp-controller="Projects" asp-action="Index" asp-active-by="Index" asp-active-type="action" class="btn-outline">See My Projects</a>
            </div>
        </div>

    </section>
    <!-- /Hero Section -->
}

<!-- Stats Section -->
<section id="stats" class="stats section">
    <div class="container" data-aos="fade-up" data-aos-delay="100">
        <div class="row gy-4">
            <div class="col-lg-3 col-md-6">
                <div class="stats-item">
                    <i class="bi bi-graph-up-arrow"></i>
                    <span data-purecounter-start="0"
                          data-purecounter-end="@Model.YearsOfExperience"
                          data-purecounter-duration="1"
                          class="purecounter"></span>
                    <p><strong>Years Experience</strong> <span>Problem solved or Features shipped</span></p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="stats-item">
                    <i class="bi bi-people"></i>
                    <span data-purecounter-start="0"
                          data-purecounter-end="@Model.TargetEndUsers"
                          data-purecounter-duration="1"
                          class="purecounter"></span>
                    <p><strong>End Users</strong> <span>Targeted by our eLearning & School System</span></p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="stats-item">
                    <i class="bi bi-headset"></i>
                    <span data-purecounter-start="0"
                          data-purecounter-end="@Model.PlanningSessions"
                          data-purecounter-duration="1"
                          class="purecounter"></span>
                    <p><strong>Planning Sessions</strong> <span>Ideas to reality</span></p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="stats-item">
                    <i class="bi bi-people"></i>
                    <span data-purecounter-start="0"
                          data-purecounter-end="@Model.TeamMembers"
                          data-purecounter-duration="1"
                          class="purecounter"></span>
                    <p><strong>Team Members</strong> <span>Friends & contributors</span></p>
                </div>
            </div>

        </div>
    </div>
</section>
<!-- Stats Section -->

<!-- Latest Updates Section -->
<section id="updates" class="updates section">
    <div class="container" data-aos="fade-up">
        
        <!-- Section Header -->
        <div class="section-header">
            <h2>Latest Updates</h2>
            <p>Conversations, insights & what's new</p>
        </div><!-- End Section Header -->

        <div class="row gy-4">
            
            <!-- Featured YouTube Episode -->
            <div class="col-lg-12">
                <div class="update-item featured">
                    <div class="row">
                        <div class="col-lg-6">
                            <!-- Video Container -->
                            <div class="video-wrapper">
                                <iframe 
                                    src="https://www.youtube.com/embed/4roFpUpSQyo"
                                    title="YouTube interview with Lancinè Koria KEITA"
                                    frameborder="0" 
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                                    allowfullscreen>
                                </iframe>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="update-content">
                                <span class="update-badge">New Episode</span>
                                <h3>Interview: Conversation with Lancinè Koria KEITA</h3>
                                <p class="update-meta">
                                    <i class="bi bi-calendar3"></i> November 25, 2025
                                    <i class="bi bi-clock ms-3"></i> 46 min
                                </p>
                                <p class="update-description">
                                    In this first episode, we discuss my academic journey, the experiences that shaped my path, and how I gradually discovered my passion for technology and digital innovation. The purpose was also to share my story to inspire, motivate, and positively impact young people who are building their own future.
                                </p>
                                <div class="update-tags">
                                    <span class="tag">Interview</span>
                                    <span class="tag">Tech Talk</span>
                                    <span class="tag">eLearning</span>
                                </div>
                                <a href="https://youtu.be/https://www.youtube.com/watch?v=4roFpUpSQyo&t=1s" target="_blank" class="btn-watch">
                                    <i class="bi bi-play-circle"></i> Watch Full Episode
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!-- End Featured Update -->

            <!-- Previous Updates / Future Posts Grid -->
            <!-- SINAGUI EDUC -->
            <div class="col-lg-4">
                <div class="update-item card">
                    <div class="card-body">
                        <span class="update-badge small">Coming Soon</span>
                        <h4>SINAGUI EDUC Platform</h4>
                        <p>
                            Our eLearning platform <strong>SINAGUI EDUC</strong> is currently in development and testing.
                            The first version will be launched soon to provide accessible digital learning opportunities.
                        </p>
                    </div>
                </div>
            </div><!-- End Update Card -->
            <!-- IT Training -->
            <div class="col-lg-4">
                <div class="update-item card">
                    <div class="card-body">
                        <span class="update-badge small">Training</span>
                        <h4>Upcoming IT Training</h4>
                        <p>
                            New online IT training sessions will be announced soon. I regularly share programming
                            knowledge and guidance with learners through online sessions and community groups.
                        </p>
                    </div>
                </div>
            </div><!-- End Update Card -->
            <!-- Social Impact -->
            <div class="col-lg-4">
                <div class="update-item card">
                    <div class="card-body">
                        <span class="update-badge small">Social Impact</span>
                        <h4>School Construction Project</h4>
                        <p>
                            On April 20, 2026, the first stone will be laid in Kankan, Guinea, marking the beginning of the construction of a new physical school dedicated to improving access to education and creating better learning opportunities for young students.
                        </p>
                    </div>
                </div>
            </div><!-- End Update Card -->

        </div>
    </div>
</section>